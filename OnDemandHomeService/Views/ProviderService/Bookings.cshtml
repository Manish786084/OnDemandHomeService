@model List<OnDemandHomeService.ViewModels.ProviderBookingVM>
@{
    Layout = "~/Views/Shared/_ProviderLayout.cshtml";
    ViewData["Title"] = "All Bookings";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 text-primary fw-bold">
            <i class="fas fa-calendar-check me-2"></i>All Bookings
        </h3>
        <span class="badge bg-primary bg-opacity-10 text-primary fs-6 py-2 px-3 rounded-pill">
            @Model.Count Total
        </span>
    </div>

    <!-- Card Wrapper for Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        @if (!Model.Any())
        {
            <!-- Empty State -->
            <div class="text-center py-5">
                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No Bookings Found</h5>
                <p class="text-muted small">Once customers book your services, they will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-center text-uppercase small font-weight-bold text-secondary border-0">
                            <th class="ps-4 text-start">Customer</th>
                            <th>Service</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Address</th>
                            <th>Phone</th>
                            <th>Amount</th>
                            <th>Status</th>
                           @*  <th>Action</th> *@
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr class="border-bottom">
                                <!-- Customer -->
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <h6 class="mb-0 fw-semibold">@b.CustomerName</h6>
                                    </div>
                                </td>

                                <!-- Service -->
                                <td class="text-center">
                                    <span class="fw-medium">@b.ServiceNames</span>
                                </td>

                                <!-- Date -->
                                <td class="text-center text-nowrap">
                                    <i class="far fa-calendar me-1 text-muted"></i> @b.BookingDate
                                </td>

                                <!-- Time -->
                                <td class="text-center text-nowrap">
                                    <i class="far fa-clock me-1 text-muted"></i> @b.TimeSlot
                                </td>

                                <!-- Address -->
                                <td>
                                    <span class="small text-muted"><i class="fas fa-map-marker-alt me-1 text-danger"></i> @b.Address</span>
                                </td>

                                <!-- Phone -->
                                <td class="text-center">
                                    <a href="tel:@b.PhoneNumber" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fas fa-phone-alt me-1"></i> @b.PhoneNumber
                                    </a>
                                </td>

                                <!-- Amount -->
                                <td class="text-center">
                                    <span class="fw-bold text-dark fs-6">₹ @b.TotalAmount</span>
                                </td>

                                <!-- Status Badges -->
                                <td class="text-center">
                                    @if (b.Status == "Pending")
                                    {
                                        <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-2 fw-semibold">
                                            <i class="fas fa-hourglass-half me-1"></i> Pending
                                        </span>
                                    }
                                    else if (b.Status == "Confirmed")
                                    {
                                        <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2 fw-semibold">
                                            <i class="fas fa-check-circle me-1"></i> Confirmed
                                        </span>
                                    }
                                    else if (b.Status == "Completed")
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 fw-semibold">
                                            <i class="fas fa-flag-checkered me-1"></i> Completed
                                        </span>
                                    }
                                    else if (b.Status == "Cancelled")
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2 fw-semibold">
                                            <i class="fas fa-times-circle me-1"></i> Cancelled
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary px-3 py-2 fw-semibold">@b.Status</span>
                                    }
                                </td>

                                <!-- Actions -->
                               @*  <td class="text-center text-nowrap">
                                    @if (b.Status == "Pending")
                                    {
                                        <form asp-action="Accept" method="post" style="display:inline"
                                              onsubmit="return confirm('Accept this booking?');">
                                            <input type="hidden" name="id" value="@b.BookingId" />
                                            <button class="btn btn-sm btn-success rounded-pill px-3 me-1" title="Accept">
                                                <i class="fas fa-check me-1"></i> Accept
                                            </button>
                                        </form>

                                        <form asp-action="Cancel" method="post" style="display:inline"
                                              onsubmit="return confirm('Cancel this booking?');">
                                            <input type="hidden" name="id" value="@b.BookingId" />
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Cancel">
                                                <i class="fas fa-times me-1"></i> Cancel
                                            </button>
                                        </form>
                                    }
                                    else if (b.Status == "Accepted")
                                    {
                                        <form asp-action="Complete" method="post" style="display:inline"
                                              onsubmit="return confirm('Mark this booking as completed?');">
                                            <input type="hidden" name="id" value="@b.BookingId" />
                                            <button class="btn btn-sm btn-primary rounded-pill px-3" title="Complete">
                                                <i class="fas fa-flag me-1"></i> Complete
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">No actions</span>
                                    }
                                </td> *@
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Initialize Bootstrap Tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}