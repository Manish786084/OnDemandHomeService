
@model OnDemandHomeService.ViewModels.ReviewsVM

@section Styles {
    <style>
        /* ===== PAGE WRAPPER ===== */
        .review-page {
            background: linear-gradient(135deg, #f8f9fc 0%, #e8ecf4 100%);
            min-height: calc(100vh - 80px);
            margin-top: -80px;
            padding-top: 120px;
            padding-bottom: 60px;
            position: relative;
            overflow: hidden;
        }

            .review-page::before {
                content: '';
                position: absolute;
                top: -200px;
                right: -200px;
                width: 500px;
                height: 500px;
                background: radial-gradient(circle, rgba(78,115,223,0.06) 0%, transparent 70%);
                border-radius: 50%;
                pointer-events: none;
            }

            .review-page::after {
                content: '';
                position: absolute;
                bottom: -150px;
                left: -150px;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(78,115,223,0.04) 0%, transparent 70%);
                border-radius: 50%;
                pointer-events: none;
            }

        /* ===== HERO HEADER ===== */
        .review-hero {
            background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
            border-radius: 20px;
            padding: 40px;
            color: #fff;
            position: relative;
            overflow: hidden;
            margin-bottom: -40px;
            z-index: 2;
            box-shadow: 0 15px 40px rgba(78,115,223,0.3);
        }

            .review-hero::before {
                content: '';
                position: absolute;
                top: -60px;
                right: -60px;
                width: 200px;
                height: 200px;
                background: rgba(255,255,255,0.06);
                border-radius: 50%;
            }

            .review-hero::after {
                content: '';
                position: absolute;
                bottom: -40px;
                left: 30%;
                width: 150px;
                height: 150px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
            }

            .review-hero h2 {
                font-size: 2rem;
                font-weight: 700;
            }

            .review-hero .subtitle {
                opacity: 0.8;
                font-size: 1.05rem;
            }

        .hero-icon {
            width: 70px;
            height: 70px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.2);
            animation: heroFloat 3s ease-in-out infinite;
        }

        @@keyframes heroFloat {
            0%, 100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }

        }

        /* ===== MAIN CARD ===== */
        .review-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.08);
            border: none;
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

            .review-card .card-body {
                padding: 50px 45px;
            }

            /* Decorative top stripe */
            .review-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 4px;
                background: linear-gradient(90deg, #4e73df, #224abe, #4e73df);
                background-size: 200% 100%;
                animation: shimmerStripe 3s linear infinite;
            }

        @@keyframes shimmerStripe {
            0%

        {
            background-position: 200% 0;
        }

        100% {
            background-position: -200% 0;
        }

        }

        /* ===== INTERACTIVE STAR RATING ===== */
        .star-rating-container {
            text-align: center;
            padding: 30px 20px;
            background: #f8f9fc;
            border-radius: 16px;
            border: 2px solid #e8ecf4;
            transition: all 0.4s ease;
            position: relative;
        }

            .star-rating-container.active {
                border-color: #4e73df;
                box-shadow: 0 0 0 4px rgba(78,115,223,0.1);
            }

            .star-rating-container:hover {
                border-color: #c5cff0;
            }

        .stars-wrapper {
            display: inline-flex;
            gap: 8px;
            margin-bottom: 16px;
        }

        .star-btn {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 3rem;
            color: #d4d8e0;
            transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            padding: 0 2px;
            line-height: 1;
        }

            .star-btn:hover {
                transform: scale(1.25) rotate(-8deg);
            }

            .star-btn.hovered {
                color: #ffc107;
                transform: scale(1.15);
                filter: drop-shadow(0 0 8px rgba(255,193,7,0.4));
            }

            .star-btn.selected {
                color: #ffc107;
                animation: starPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                filter: drop-shadow(0 0 10px rgba(255,193,7,0.5));
            }

        @@keyframes starPop {
            0%

        {
            transform: scale(1);
        }

        40% {
            transform: scale(1.4) rotate(10deg);
        }

        70% {
            transform: scale(0.9) rotate(-5deg);
        }

        100% {
            transform: scale(1.1) rotate(0deg);
        }

        }

        /* Rating burst particles */
        .star-burst {
            position: absolute;
            pointer-events: none;
        }

        .burst-particle {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #ffc107;
            animation: burstOut 0.6s ease-out forwards;
        }

        @@keyframes burstOut {
            0%

        {
            transform: translate(0, 0) scale(1);
            opacity: 1;
        }

        100% {
            opacity: 0;
        }

        }

        /* Feedback Label */
        .rating-feedback {
            font-size: 1.1rem;
            font-weight: 600;
            color: #5a5c69;
            min-height: 32px;
            transition: all 0.3s ease;
        }

            .rating-feedback .feedback-emoji {
                font-size: 1.6rem;
                margin-right: 6px;
                display: inline-block;
                animation: emojiBounce 0.5s ease;
            }

        @@keyframes emojiBounce {
            0%

        {
            transform: scale(0);
        }

        50% {
            transform: scale(1.3);
        }

        100% {
            transform: scale(1);
        }

        }

        /* Hidden Select (actual form value) */
        .rating-hidden-select {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        /* ===== SECTION LABELS ===== */
        .form-section-label {
            font-weight: 700;
            color: #224abe;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .form-section-label i {
                font-size: 1rem;
            }

            .form-section-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg, #e0e5f1, transparent);
            }

        /* ===== TEXTAREA ===== */
        .comment-textarea {
            border: 2px solid #e8ecf4;
            border-radius: 14px;
            padding: 18px 20px;
            font-size: 1rem;
            resize: vertical;
            min-height: 140px;
            transition: all 0.3s ease;
            background: #fafbfe;
        }

            .comment-textarea:focus {
                border-color: #4e73df;
                box-shadow: 0 0 0 4px rgba(78,115,223,0.1);
                background: #fff;
            }

            .comment-textarea::placeholder {
                color: #b0b5c3;
            }

        /* Character Counter */
        .char-counter {
            text-align: right;
            font-size: 0.82rem;
            color: #b0b5c3;
            margin-top: 8px;
            transition: color 0.3s;
        }

            .char-counter.warning {
                color: #f0ad4e;
            }

            .char-counter.danger {
                color: #e74a3b;
            }

        /* ===== QUICK TAGS ===== */
        .quick-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 12px;
        }

        .quick-tag {
            padding: 6px 16px;
            border-radius: 50px;
            border: 1.5px solid #e0e5f1;
            background: #fff;
            color: #5a5c69;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.25s ease;
            user-select: none;
        }

            .quick-tag:hover {
                border-color: #4e73df;
                color: #4e73df;
                background: rgba(78,115,223,0.04);
            }

            .quick-tag.active {
                background: linear-gradient(135deg, #4e73df, #224abe);
                color: #fff;
                border-color: transparent;
                box-shadow: 0 4px 12px rgba(78,115,223,0.25);
                animation: tagPop 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
            }

        @@keyframes tagPop {
            0%

        {
            transform: scale(0.9);
        }

        50% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }

        }

        /* ===== SUBMIT BUTTON ===== */
        .submit-btn {
            background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
            color: #fff;
            border: none;
            padding: 16px 48px;
            border-radius: 50px;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(78,115,223,0.3);
            position: relative;
            overflow: hidden;
        }

            .submit-btn::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                transition: left 0.5s;
            }

            .submit-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 35px rgba(78,115,223,0.45);
            }

                .submit-btn:hover::before {
                    left: 100%;
                }

            .submit-btn:active {
                transform: translateY(-1px);
            }

            .submit-btn:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

            .submit-btn .btn-text {
                transition: all 0.3s;
            }

            .submit-btn .btn-loader {
                display: none;
                width: 22px;
                height: 22px;
                border: 3px solid rgba(255,255,255,0.3);
                border-top-color: #fff;
                border-radius: 50%;
                animation: spin 0.7s linear infinite;
            }

            .submit-btn.loading .btn-text {
                display: none;
            }

            .submit-btn.loading .btn-loader {
                display: inline-block;
            }

        @@keyframes spin {
            to

        {
            transform: rotate(360deg);
        }

        }

        /* ===== SUCCESS OVERLAY ===== */
        .success-overlay {
            position: fixed;
            inset: 0;
            background: rgba(34,74,190,0.85);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }

            .success-overlay.visible {
                opacity: 1;
                pointer-events: auto;
            }

        .success-content {
            text-align: center;
            color: #fff;
            transform: scale(0.8) translateY(20px);
            transition: transform 0.5s cubic-bezier(0.175,0.885,0.32,1.275);
        }

        .success-overlay.visible .success-content {
            transform: scale(1) translateY(0);
        }

        .success-checkmark {
            width: 100px;
            height: 100px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 3rem;
            animation: successPulse 1.5s ease-in-out infinite;
        }

        @@keyframes successPulse {
            0%, 100%

        {
            box-shadow: 0 0 0 0 rgba(255,255,255,0.2);
        }

        50% {
            box-shadow: 0 0 0 20px rgba(255,255,255,0);
        }

        }

        .success-checkmark i {
            animation: checkDraw 0.6s 0.3s ease both;
        }

        @@keyframes checkDraw {
            0%

        {
            opacity: 0;
            transform: scale(0) rotate(-45deg);
        }

        100% {
            opacity: 1;
            transform: scale(1) rotate(0deg);
        }

        }

        /* ===== CONFETTI ===== */
        .confetti-piece {
            position: fixed;
            width: 10px;
            height: 10px;
            z-index: 10000;
            pointer-events: none;
        }

        /* ===== VALIDATION STYLING ===== */
        .field-validation-error {
            color: #e74a3b;
            font-size: 0.85rem;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 4px;
            animation: shakeError 0.4s ease;
        }

        @@keyframes shakeError {
            0%, 100%

        {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-6px);
        }

        50% {
            transform: translateX(6px);
        }

        75% {
            transform: translateX(-4px);
        }

        }

        .input-validation-error {
            border-color: #e74a3b !important;
            box-shadow: 0 0 0 3px rgba(231,74,59,0.1) !important;
        }

        /* ===== ENTRY ANIMATIONS ===== */
        .fade-up {
            opacity: 0;
            transform: translateY(25px);
            animation: fadeUpIn 0.6s ease forwards;
        }

        @@keyframes fadeUpIn {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .delay-1 {
            animation-delay: 0.1s;
        }

        .delay-2 {
            animation-delay: 0.2s;
        }

        .delay-3 {
            animation-delay: 0.3s;
        }

        .delay-4 {
            animation-delay: 0.4s;
        }

        .delay-5 {
            animation-delay: 0.5s;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 768px) {
            .review-hero {
                padding: 28px 24px;
            }

                .review-hero h2 {
                    font-size: 1.5rem;
                }

            .review-card .card-body {
                padding: 30px 22px;
            }

            .star-btn {
                font-size: 2.2rem;
            }

            .submit-btn {
                width: 100%;
                padding: 16px;
            }
        }
    </style>
}

<div class="review-page">
    <div class="container">

        <!-- ===== HERO HEADER ===== -->
        <div class="review-hero fade-up mb-5">
            <div class="d-flex align-items-center gap-4 position-relative" style="z-index:1;">
                <div class="hero-icon">
                    <i class="fas fa-star"></i>
                </div>
                <div>
                    <h2 class="mb-1">Rate Your Service</h2>
                    <p class="subtitle mb-0">Your feedback helps us improve and rewards great professionals</p>
                </div>
            </div>
        </div>

        <!-- ===== MAIN CARD ===== -->
        <div class="review-card fade-up delay-2">
            <div class="card-body">

                <form asp-action="GiveReview" method="post" id="reviewForm" novalidate>

                    <input type="hidden" asp-for="BookingId" />
                    <input type="hidden" asp-for="ProviderId" />

                    <!-- ===== STAR RATING ===== -->
                    <div class="fade-up delay-2">
                        <div class="form-section-label">
                            <i class="fas fa-star-half-alt"></i> How Would You Rate This Service?
                        </div>

                        <div class="star-rating-container" id="starContainer">
                            <!-- Hidden actual select for model binding -->
                            <select asp-for="Rating" class="rating-hidden-select" id="ratingSelect">
                                <option value="">Select Rating</option>
                                <option value="5">5</option>
                                <option value="4">4</option>
                                <option value="3">3</option>
                                <option value="2">2</option>
                                <option value="1">1</option>
                            </select>

                            <!-- Interactive Stars -->
                            <div class="stars-wrapper" id="starsWrapper">
                                <button type="button" class="star-btn" data-value="1" aria-label="1 star">★</button>
                                <button type="button" class="star-btn" data-value="2" aria-label="2 stars">★</button>
                                <button type="button" class="star-btn" data-value="3" aria-label="3 stars">★</button>
                                <button type="button" class="star-btn" data-value="4" aria-label="4 stars">★</button>
                                <button type="button" class="star-btn" data-value="5" aria-label="5 stars">★</button>
                            </div>

                            <div class="rating-feedback" id="ratingFeedback"></div>
                        </div>
                        <span asp-validation-for="Rating" class="field-validation-error" id="ratingError"></span>
                    </div>

                    <!-- ===== QUICK FEEDBACK TAGS ===== -->
                    <div class="mt-4 fade-up delay-3">
                        <div class="form-section-label">
                            <i class="fas fa-tags"></i> Quick Feedback
                        </div>
                        <div class="quick-tags" id="quickTags">
                            <span class="quick-tag" data-text="Punctual">⏰ Punctual</span>
                            <span class="quick-tag" data-text="Professional">💼 Professional</span>
                            <span class="quick-tag" data-text="Friendly">😊 Friendly</span>
                            <span class="quick-tag" data-text="Clean Work">✨ Clean Work</span>
                            <span class="quick-tag" data-text="Knowledgeable">🧠 Knowledgeable</span>
                            <span class="quick-tag" data-text="Good Communication">🗣️ Good Communication</span>
                            <span class="quick-tag" data-text="Went Above & Beyond">🚀 Went Above &amp; Beyond</span>
                            <span class="quick-tag" data-text="Fair Pricing">💰 Fair Pricing</span>
                        </div>
                    </div>

                    <!-- ===== COMMENT ===== -->
                    <div class="mt-4 fade-up delay-4">
                        <div class="form-section-label">
                            <i class="fas fa-comment-dots"></i> Tell Us More
                        </div>
                        <textarea asp-for="Comment"
                                  class="form-control comment-textarea"
                                  rows="5"
                                  placeholder="Share the details of your experience — what went well, what could improve..."
                                  maxlength="500"
                                  id="commentBox"></textarea>
                        <div class="char-counter" id="charCounter">0 / 500</div>
                        <span asp-validation-for="Comment" class="field-validation-error"></span>
                    </div>

                    <!-- ===== SUBMIT ===== -->
                    <div class="mt-4 text-end fade-up delay-5">
                        <button type="submit" class="submit-btn" id="submitBtn">
                            <span class="btn-text"><i class="fas fa-paper-plane me-2"></i>Submit Review</span>
                            <span class="btn-loader"></span>
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

<!-- ===== SUCCESS OVERLAY ===== -->
<div class="success-overlay" id="successOverlay">
    <div class="success-content">
        <div class="success-checkmark">
            <i class="fas fa-check"></i>
        </div>
        <h2 class="fw-bold mb-2">Thank You!</h2>
        <p class="lead mb-4 opacity-75">Your review has been submitted successfully.</p>
        <a asp-controller="Home" asp-action="Index"
           class="btn btn-warning btn-lg px-5 fw-bold"
           style="border-radius:50px; box-shadow:0 8px 25px rgba(255,193,7,0.35);">
            <i class="fas fa-home me-2"></i>Back to Home
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ============================================
        // CONFIGURATION
        // ============================================
        const feedbackMap = {
            1: { emoji: '😡', text: 'Terrible', color: '#e74a3b' },
            2: { emoji: '😞', text: 'Poor', color: '#f0ad4e' },
            3: { emoji: '😐', text: 'Average', color: '#858796' },
            4: { emoji: '😊', text: 'Very Good', color: '#4e73df' },
            5: { emoji: '🤩', text: 'Excellent!', color: '#1cc88a' }
        };

        let selectedRating = 0;

        // ============================================
        // STAR RATING — HOVER & CLICK
        // ============================================
        const stars = document.querySelectorAll('.star-btn');
        const starsWrapper = document.getElementById('starsWrapper');
        const ratingSelect = document.getElementById('ratingSelect');
        const ratingFeedback = document.getElementById('ratingFeedback');
        const starContainer = document.getElementById('starContainer');

        stars.forEach(star => {
            // Hover in
            star.addEventListener('mouseenter', function () {
                const val = parseInt(this.dataset.value);
                highlightStars(val, 'hovered');
            });

            // Hover out
            star.addEventListener('mouseleave', function () {
                clearHover();
                if (selectedRating > 0) highlightStars(selectedRating, 'selected');
            });

            // Click to select
            star.addEventListener('click', function () {
                const val = parseInt(this.dataset.value);
                selectedRating = val;
                ratingSelect.value = val;

                // Trigger validation clear
                const errorEl = document.getElementById('ratingError');
                if (errorEl) errorEl.textContent = '';

                clearHover();
                highlightStars(val, 'selected');
                showFeedback(val);
                starContainer.classList.add('active');
                createBurstParticles(this);
            });
        });

        function highlightStars(upTo, className) {
            stars.forEach(star => {
                const v = parseInt(star.dataset.value);
                star.classList.remove('hovered', 'selected');
                if (v <= upTo) star.classList.add(className);
            });
        }

        function clearHover() {
            stars.forEach(s => s.classList.remove('hovered'));
        }

        function showFeedback(val) {
            const fb = feedbackMap[val];
            if (!fb) return;
            ratingFeedback.innerHTML = `<span class="feedback-emoji">${fb.emoji}</span> <span style="color:${fb.color}">${fb.text}</span>`;
        }

        // Burst particles on star click
        function createBurstParticles(starEl) {
            const rect = starEl.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;

            for (let i = 0; i < 8; i++) {
                const p = document.createElement('div');
                p.classList.add('burst-particle');
                p.style.position = 'fixed';
                p.style.left = cx + 'px';
                p.style.top = cy + 'px';
                p.style.zIndex = '9999';
                p.style.pointerEvents = 'none';

                const angle = (Math.PI * 2 / 8) * i;
                const dist = 25 + Math.random() * 20;
                const tx = Math.cos(angle) * dist;
                const ty = Math.sin(angle) * dist;

                p.style.animation = 'none';
                document.body.appendChild(p);

                p.animate([
                    { transform: 'translate(0,0) scale(1)', opacity: 1 },
                    { transform: `translate(${tx}px,${ty}px) scale(0)`, opacity: 0 }
                ], { duration: 500, easing: 'ease-out' });

                setTimeout(() => p.remove(), 500);
            }
        }

        // ============================================
        // QUICK TAGS — TOGGLE INTO COMMENT
        // ============================================
        const quickTags = document.querySelectorAll('.quick-tag');
        const commentBox = document.getElementById('commentBox');
        const activeTags = new Set();

        quickTags.forEach(tag => {
            tag.addEventListener('click', function () {
                const text = this.dataset.text;

                if (this.classList.contains('active')) {
                    this.classList.remove('active');
                    activeTags.delete(text);
                } else {
                    this.classList.add('active');
                    activeTags.add(text);
                }

                updateCommentFromTags();
            });
        });

        function updateCommentFromTags() {
            // Preserve any custom text the user typed after the tag section
            const tagLine = activeTags.size > 0
                ? 'Highlights: ' + [...activeTags].join(', ') + '. '
                : '';

            // If the comment only has the auto-generated tag line, replace it
            const currentText = commentBox.value;
            const prevTagPrefix = currentText.match(/^Highlights:.*?\.\s*/);

            if (prevTagPrefix) {
                commentBox.value = tagLine + currentText.substring(prevTagPrefix[0].length);
            } else if (!currentText.trim() || currentText.trim().startsWith('Highlights:')) {
                commentBox.value = tagLine;
            } else {
                // User has custom text — prepend tags
                const withoutOldTags = currentText.replace(/^Highlights:.*?\.\s*/, '');
                commentBox.value = tagLine + withoutOldTags;
            }

            updateCharCounter();
        }

        // ============================================
        // CHARACTER COUNTER
        // ============================================
        const charCounter = document.getElementById('charCounter');
        const maxLen = 500;

        commentBox.addEventListener('input', updateCharCounter);

        function updateCharCounter() {
            const len = commentBox.value.length;
            charCounter.textContent = `${len} / ${maxLen}`;

            charCounter.classList.remove('warning', 'danger');
            if (len > maxLen * 0.9) charCounter.classList.add('danger');
            else if (len > maxLen * 0.75) charCounter.classList.add('warning');
        }

        // ============================================
        // FORM SUBMIT — LOADING + SUCCESS
        // ============================================
        const reviewForm = document.getElementById('reviewForm');
        const submitBtn = document.getElementById('submitBtn');
        const successOverlay = document.getElementById('successOverlay');

        reviewForm.addEventListener('submit', function (e) {
            // Validate rating
            if (!selectedRating || selectedRating === 0) {
                e.preventDefault();
                const errorEl = document.getElementById('ratingError');
                if (errorEl) {
                    errorEl.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i>Please select a rating';
                }
                starContainer.style.animation = 'shakeError 0.4s ease';
                setTimeout(() => starContainer.style.animation = '', 400);
                return;
            }

            // Show loading state
            submitBtn.classList.add('loading');
            submitBtn.disabled = true;

            // If AJAX — for standard form, the page will redirect
            // We add a brief delay so the user sees the spinner
            setTimeout(() => {
                // If we're still on the page (e.g. validation failed on server),
                // the form will naturally reload. For AJAX-style, show success:
                // successOverlay.classList.add('visible');
                // launchConfetti();
            }, 800);
        });

        // ============================================
        // CONFETTI (for AJAX success scenario)
        // ============================================
        function launchConfetti() {
            const colors = ['#4e73df', '#224abe', '#ffc107', '#1cc88a', '#f0ad4e', '#e74a3b', '#fff'];

            for (let i = 0; i < 60; i++) {
                const piece = document.createElement('div');
                piece.classList.add('confetti-piece');
                piece.style.left = Math.random() * 100 + 'vw';
                piece.style.top = '-20px';
                piece.style.width = (Math.random() * 8 + 5) + 'px';
                piece.style.height = (Math.random() * 8 + 5) + 'px';
                piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';

                document.body.appendChild(piece);

                const drift = (Math.random() - 0.5) * 200;
                const duration = 1500 + Math.random() * 2000;

                piece.animate([
                    { transform: `translateX(0) rotate(0deg)`, opacity: 1 },
                    { transform: `translateX(${drift}px) rotate(${360 + Math.random()*360}deg)`, opacity: 0, top: '110vh' }
                ], {
                    duration: duration,
                    easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
                });

                setTimeout(() => piece.remove(), duration);
            }
        }

        // ============================================
        // AUTO-DETECT SERVER VALIDATION ERRORS
        // If the page reloads with validation errors,
        // restore the star state from the hidden select
        // ============================================
        (function restoreState() {
            const val = parseInt(ratingSelect.value);
            if (val >= 1 && val <= 5) {
                selectedRating = val;
                highlightStars(val, 'selected');
                showFeedback(val);
                starContainer.classList.add('active');
            }

            // Init char counter
            updateCharCounter();
        })();
    </script>
}