@{
    Layout = "_Layout";
    ViewData["Title"] = "Home Services On Demand";
}

<!-- Page Specific Styles -->
@section Styles {
    <style>
        /* Hero Section */
        .hero-section {
            background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
            min-height: 600px;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            color: #fff;
            margin-top: -80px; /* Offset fixed navbar padding */
            padding-top: 80px; /* Adjust for content */
            border-radius: 0 0 50px 0;
        }

        .hero-shape {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 150px;
            background: #fff;
            clip-path: polygon(0 100%, 100% 0, 100% 100%);
        }

        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .hero-search-box {
            background: #fff;
            border-radius: 50px;
            padding: 10px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
            display: flex;
        }

            .hero-search-box input {
                border: none;
                padding: 15px 25px;
                font-size: 1rem;
                flex-grow: 1;
            }

                .hero-search-box input:focus {
                    outline: none;
                }

            .hero-search-box button {
                border-radius: 50px;
                padding: 10px 30px;
                font-weight: 600;
            }

        /* Categories */
        .category-card {
            background: #fff;
            border-radius: 15px;
            padding: 30px 20px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            cursor: pointer;
            border: 1px solid transparent;
            height: 100%;
        }

            .category-card:hover {
                transform: translateY(-10px);
                border-color: var(--primary);
                box-shadow: 0 15px 30px rgba(78, 115, 223, 0.1);
            }

        .category-icon {
            width: 80px;
            height: 80px;
            background: var(--light-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2rem;
            color: var(--primary);
            transition: all 0.3s;
        }

        .category-card:hover .category-icon {
            background: var(--primary);
            color: #fff;
        }

        /* Providers */
        .provider-card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: transform 0.3s;
        }

            .provider-card:hover {
                transform: scale(1.03);
            }

        .provider-img {
            height: 200px;
            object-fit: cover;
        }

        .rating-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: #fff;
            padding: 5px 10px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.8rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        @@media (max-width: 768px) {
            .hero-content h1

        {
            font-size: 2rem;
        }

        .hero-search-box {
            flex-direction: column;
            border-radius: 15px;
        }

            .hero-search-box input {
                width: 100%;
                margin-bottom: 10px;
            }

            .hero-search-box button {
                width: 100%;
            }

        }
    </style>
}

<!-- ========================================= -->
<!-- HERO SECTION -->
<!-- ========================================= -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1>Home Services <br>At Your Fingertips.</h1>
                    <p class="lead mb-4">Find trusted professionals for cleaning, plumbing, electrical work, and more.</p>

                    <div class="hero-search-box">
                        <input type="text" placeholder="What service do you need?">
                        <button class="btn btn-warning btn-lg"><i class="fas fa-search me-2"></i>Search</button>
                    </div>

                    <div class="mt-4 d-flex align-items-center">
                        <span class="me-3 small">Popular:</span>
                        <span class="badge bg-white text-dark me-2 p-2">Cleaning</span>
                        <span class="badge bg-white text-dark p-2">Plumbing</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <img src="https://bootstrapmade.com/demo/templates/Logis/assets/img/hero-img.png" class="img-fluid" style="filter: drop-shadow(0 20px 30px rgba(0,0,0,0.3));" alt="Service Illustration">
            </div>
        </div>
    </div>
    <div class="hero-shape"></div>
</section>

<!-- ========================================= -->
<!-- CATEGORIES SECTION -->
<!-- ========================================= -->
<section id="services" class="py-5 mt-5">
