        </div>

        <div class="row g-4">
            <div class="col-lg-2 col-md-4 col-6">
                <div class="category-card">
                    <div class="category-icon"><i class="fas fa-broom"></i></div>
                    <h6>Cleaning</h6>
                    <small class="text-muted">120 Pros</small>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="category-card">
                    <div class="category-icon"><i class="fas fa-wrench"></i></div>
                    <h6>Plumbing</h6>
                    <small class="text-muted">85 Pros</small>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="category-card">
                    <div class="category-icon"><i class="fas fa-bolt"></i></div>
                    <h6>Electrician</h6>
                    <small class="text-muted">92 Pros</small>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="category-card">
                    <div class="category-icon"><i class="fas fa-paint-roller"></i></div>
                    <h6>Painting</h6>
                    <small class="text-muted">45 Pros</small>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="category-card">
                    <div class="category-icon"><i class="fas fa-truck-moving"></i></div>
                    <h6>Moving</h6>
                    <small class="text-muted">30 Pros</small>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="category-card">
                    <div class="category-icon"><i class="fas fa-air-conditioner"></i></div>
                    <h6>AC Repair</h6>
                    <small class="text-muted">55 Pros</small>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========================================= -->
