    <script>
        /* ==========================================
           PARTICLE SYSTEM — floating warning particles
        ========================================== */
        const canvas = document.getElementById('particles-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        const PARTICLE_COUNT = 50;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        class Particle {
            constructor() {
                this.reset();
            }
            reset() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 0.5;
                this.speedX = (Math.random() - 0.5) * 0.3;
                this.speedY = (Math.random() - 0.5) * 0.3;
                this.opacity = Math.random() * 0.3 + 0.05;
                this.isRed = Math.random() > 0.6;
            }
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                if (this.x < -10 || this.x > canvas.width + 10 || this.y < -10 || this.y > canvas.height + 10) {
                    this.reset();
                }
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                if (this.isRed) {
                    ctx.fillStyle = `rgba(255, 46, 46, ${this.opacity})`;
                } else {
                    ctx.fillStyle = `rgba(255, 140, 0, ${this.opacity * 0.6})`;
                }
                ctx.fill();
            }
        }

        for (let i = 0; i < PARTICLE_COUNT; i++) {
            particles.push(new Particle());
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Draw connection lines between nearby particles
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 150) {
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        const lineOpacity = (1 - dist / 150) * 0.06;
                        ctx.strokeStyle = `rgba(255, 46, 46, ${lineOpacity})`;
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }

            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        /* ==========================================
           LIVE CLOCK
        ========================================== */
        function updateClock() {
            const now = new Date();
            const str = now.toLocaleTimeString('en-US', { hour12: false }) + '.' + String(now.getMilliseconds()).padStart(3, '0');
            document.getElementById('liveTime').textContent = str;
        }
        setInterval(updateClock, 50);
        updateClock();

        /* ==========================================
           METADATA
        ========================================== */
        function generateId(len) {
            const chars = 'ABCDEF0123456789';
            let id = '';
            for (let i = 0; i < len; i++) id += chars[Math.floor(Math.random() * chars.length)];
            return id;
        }

        document.getElementById('reqId').textContent = 'REQ-' + generateId(8);
        document.getElementById('eventId').textContent = 'EVT-' + generateId(6);
        document.getElementById('timestamp').textContent = new Date().toISOString();
        // Simulated IP (never actual IP)
        document.getElementById('clientIp').textContent = '192.168.' + Math.floor(Math.random() * 255) + '.' + Math.floor(Math.random() * 255);

        /* ==========================================
           WARNING LIST STAGGERED REVEAL
        ========================================== */
        const warningItems = document.querySelectorAll('.warning-list li');
        warningItems.forEach((item, i) => {
            setTimeout(() => {
                item.classList.add('visible');
            }, 1600 + i * 150);
        });

        /* ==========================================
           TERMINAL TYPING EFFECT
        ========================================== */
        const terminalLines = document.querySelectorAll('.terminal-line');
        terminalLines.forEach((line, i) => {
            setTimeout(() => {
                line.classList.add('typed');
            }, 2400 + i * 400);
        });

        /* ==========================================
           SECURITY SCAN BAR
        ========================================== */
        let scanProgress = 0;
        const scanBar = document.getElementById('scanBar');
        const scanPercent = document.getElementById('scanPercent');
        const scanInterval = setInterval(() => {
            scanProgress += Math.random() * 3 + 0.5;
            if (scanProgress >= 100) {
                scanProgress = 100;
                clearInterval(scanInterval);
            }
            scanBar.style.width = scanProgress + '%';
            scanPercent.textContent = Math.floor(scanProgress) + '%';
        }, 80);

        /* ==========================================
           COUNTDOWN
        ========================================== */
        let countdown = 15;
        const countdownEl = document.getElementById('countdownNum');
        const countdownInterval = setInterval(() => {
            countdown--;
            if (countdown <= 0) {
                clearInterval(countdownInterval);
                countdownEl.textContent = '0';
                showToast('fa-rotate', 'Redirecting to homepage...');
                setTimeout(() => goHome(), 800);
            } else {
                countdownEl.textContent = countdown;
            }
        }, 1000);

        /* ==========================================
           TOAST SYSTEM
        ========================================== */
        function showToast(icon, message) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast-msg';
            toast.innerHTML = `<i class="fa-solid ${icon}"></i><span>${message}</span>`;
            container.appendChild(toast);

            setTimeout(() => {
                toast.classList.add('leaving');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Initial warning toast
        setTimeout(() => {
            showToast('fa-shield-halved', 'Security violation has been logged.');
        }, 4000);

        setTimeout(() => {
            showToast('fa-user-slash', 'Insufficient clearance for requested resource.');
        }, 6000);

        /* ==========================================
           BUTTON ACTIONS
        ========================================== */
        function goBack() {
            clearInterval(countdownInterval);
            showToast('fa-arrow-left', 'Navigating to previous page...');
            setTimeout(() => {
                if (window.history.length > 1) {
                    window.history.back();
                } else {
                    window.location.href = '/';
                }
            }, 600);
        }

        function goHome() {
            clearInterval(countdownInterval);
            showToast('fa-house', 'Redirecting to homepage...');
            setTimeout(() => {
                window.location.href = '/';
            }, 600);
        }

        function contactAdmin() {
            clearInterval(countdownInterval);
            showToast('fa-headset', 'Opening administrator contact channel...');
            // Simulate a modal-like inline response
            setTimeout(() => {
                showToast('fa-envelope', 'Admin notified: support@system.internal');
            }, 1500);
        }

        /* ==========================================
           KEYBOARD SHORTCUT
        ========================================== */
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                goBack();
            }
            if (e.key === 'h' || e.key === 'H') {
                goHome();
            }
        });
    </script>
</body>
