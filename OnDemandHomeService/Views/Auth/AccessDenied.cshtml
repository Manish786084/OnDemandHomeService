            }

            .lock-icon-wrapper {
                width: 120px;
                height: 120px;
                font-size: 3rem;
            }

            .lock-container {
                width: 120px;
                height: 120px;
            }

            .denied-hero {
                min-height: 500px;
            }
        }
    </style>
}

<!-- ========================================= -->
<!-- HERO SECTION -->
<!-- ========================================= -->
<section class="denied-hero" id="deniedHero">
    <div class="grid-overlay"></div>
    <div class="scan-line"></div>

    <!-- Particles injected by JS -->
    <div id="particleContainer"></div>

    <div class="container position-relative" style="z-index:3;">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <!-- Animated Lock -->
                <div class="lock-container" id="lockContainer" title="Click to shake!">
                    <div class="lock-ring"></div>
                    <div class="lock-ring-reverse"></div>
                    <div class="pulse-ring"></div>
                    <div class="pulse-ring"></div>
                    <div class="pulse-ring"></div>
                    <div class="lock-icon-wrapper" id="lockIcon">
                        <i class="fas fa-lock"></i>
                    </div>
                </div>

                <!-- Glitch Text -->
                <h1 class="glitch-text" data-text="Access Denied">Access Denied</h1>
                <p class="error-code">ERROR 403 — FORBIDDEN</p>

                <!-- Typing Subtitle -->
                <p class="lead mt-3 mb-4">
                    <span class="typing-text" id="typingText"></span>
                </p>

                <!-- Action Buttons -->
                <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
                    <a asp-controller="Home" asp-action="Index"
                       class="action-btn btn-primary-action ripple-container"
                       id="btnGoHome">
                        <i class="fas fa-home me-2"></i>Go Home
                    </a>
                    <button class="action-btn btn-secondary-action ripple-container"
                            id="btnGoBack"
                            onclick="history.back()">
                        <i class="fas fa-arrow-left me-2"></i>Go Back
                    </button>
                </div>

                <!-- Redirect Progress Bar -->
                <div class="redirect-bar" id="redirectBar">
                    <div class="bar-fill" id="barFill"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="hero-shape"></div>
</section>

<!-- ========================================= -->
<!-- POSSIBLE REASONS -->
<!-- ========================================= -->
<section class="py-5" id="reasonsSection">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3">Why This Happened</span>
            <h2 class="fw-bold">Possible Reasons</h2>
            <p class="text-muted mt-2">Here are the most common causes for access denial</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="reason-card" data-delay="0">
                    <div class="reason-icon"><i class="fas fa-user-lock"></i></div>
                    <h6 class="fw-bold">Insufficient Permissions</h6>
                    <p class="text-muted small">Your account role doesn't have the required privileges to view this resource.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="reason-card" data-delay="100">
                    <div class="reason-icon"><i class="fas fa-key"></i></div>
                    <h6 class="fw-bold">Authentication Expired</h6>
                    <p class="text-muted small">Your login session may have timed out. Try signing in again to regain access.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="reason-card" data-delay="200">
                    <div class="reason-icon"><i class="fas fa-ban"></i></div>
                    <h6 class="fw-bold">Restricted Area</h6>
                    <p class="text-muted small">This section is reserved for administrators and authorized personnel only.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="reason-card" data-delay="300">
                    <div class="reason-icon"><i class="fas fa-shield-alt"></i></div>
                    <h6 class="fw-bold">Security Trigger</h6>
                    <p class="text-muted small">Unusual activity was detected and access was blocked to protect your account.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========================================= -->
<!-- WHAT YOU CAN DO -->
<!-- ========================================= -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3">Next Steps</span>
                <h2 class="fw-bold mb-3">What You Can Do</h2>
                <p class="text-muted">
                    Don't worry — this is usually easy to fix. Follow the steps below
                    to resolve the issue and get back on track.
                </p>
                <a asp-controller="Home" asp-action="Index"
                   class="action-btn btn-primary-action ripple-container mt-3">
                    <i class="fas fa-home me-2"></i>Return to Safety
                </a>
            </div>
            <div class="col-lg-7">
                <!-- Step 1 -->
                <div class="d-flex align-items-start mb-4 step-connector">
                    <div class="step-number me-4">1</div>
                    <div>
                        <h6 class="fw-bold mb-1">Verify Your Login Status</h6>
                        <p class="text-muted small mb-0">Make sure you're logged into the correct account with the right permissions. Check the top-right corner for your profile icon.</p>
                    </div>
                </div>
                <!-- Step 2 -->
                <div class="d-flex align-items-start mb-4 step-connector">
                    <div class="step-number me-4">2</div>
                    <div>
                        <h6 class="fw-bold mb-1">Request Access from Admin</h6>
                        <p class="text-muted small mb-0">If you believe you should have access, contact your system administrator and request the appropriate role or permission level.</p>
                    </div>
                </div>
                <!-- Step 3 -->
                <div class="d-flex align-items-start mb-4 step-connector">
                    <div class="step-number me-4">3</div>
                    <div>
                        <h6 class="fw-bold mb-1">Clear Browser Cache</h6>
                        <p class="text-muted small mb-0">Sometimes stale cookies or cached tokens cause authentication issues. Clear your browser data and try loading the page again.</p>
                    </div>
                </div>
                <!-- Step 4 -->
                <div class="d-flex align-items-start step-connector">
                    <div class="step-number me-4">4</div>
                    <div>
                        <h6 class="fw-bold mb-1">Contact Support</h6>
                        <p class="text-muted small mb-0">If the problem persists, reach out to our support team with the error code <strong>403</strong> and we'll investigate right away.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========================================= -->
<!-- CTA BANNER -->
<!-- ========================================= -->
<section class="py-5">
    <div class="container">
        <div class="cta-banner text-center position-relative" style="z-index:1;">
            <h2 class="fw-bold mb-3">Ready to Get Back In?</h2>
            <p class="lead mb-4 opacity-75">Sign in with the correct account or contact your administrator for access.</p>
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Login"
                   class="action-btn ripple-container"
                   style="background:#ffc107; color:#224abe; font-weight:700; box-shadow:0 8px 25px rgba(255,193,7,0.35);">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </a>
                <a asp-controller="Home" asp-action="Index"
                   class="action-btn ripple-container"
                   style="background:rgba(255,255,255,0.15); color:#fff; border:1px solid rgba(255,255,255,0.3);">
                    <i class="fas fa-headset me-2"></i>Contact Support
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // ============================================
        // TYPING EFFECT
        // ============================================
        const phrases = [
            "You don't have permission to access this resource.",
            "This area is restricted to authorized users only.",
            "Please verify your credentials and try again.",
            "If you believe this is an error, contact support."
        ];
        let phraseIdx = 0, charIdx = 0, isDeleting = false;
        const typingEl = document.getElementById('typingText');

        function typeLoop() {
            const current = phrases[phraseIdx];
            if (!isDeleting) {
                typingEl.textContent = current.substring(0, charIdx + 1);
                charIdx++;
                if (charIdx === current.length) {
                    isDeleting = true;
                    setTimeout(typeLoop, 2000);
                    return;
                }
                setTimeout(typeLoop, 45);
            } else {
                typingEl.textContent = current.substring(0, charIdx - 1);
                charIdx--;
                if (charIdx === 0) {
                    isDeleting = false;
                    phraseIdx = (phraseIdx + 1) % phrases.length;
                    setTimeout(typeLoop, 400);
                    return;
                }
                setTimeout(typeLoop, 25);
            }
        }
        typeLoop();

        // ============================================
        // LOCK SHAKE ON CLICK
        // ============================================
        const lockContainer = document.getElementById('lockContainer');
        lockContainer.addEventListener('click', function () {
            this.classList.remove('shaking');
            void this.offsetWidth; // reflow
            this.classList.add('shaking');
            setTimeout(() => this.classList.remove('shaking'), 600);
        });

        // ============================================
        // FLOATING PARTICLES
        // ============================================
        const particleContainer = document.getElementById('particleContainer');
        function createParticles() {
            for (let i = 0; i < 25; i++) {
                const p = document.createElement('div');
                p.classList.add('particle');
                const size = Math.random() * 6 + 3;
                p.style.width = size + 'px';
                p.style.height = size + 'px';
                p.style.left = Math.random() * 100 + '%';
                p.style.bottom = '-20px';
                p.style.animationDuration = (Math.random() * 8 + 6) + 's';
                p.style.animationDelay = (Math.random() * 10) + 's';
                particleContainer.appendChild(p);
            }
        }
        createParticles();

        // ============================================
        // RIPPLE EFFECT ON BUTTONS
        // ============================================
        document.querySelectorAll('.ripple-container').forEach(btn => {
            btn.addEventListener('click', function (e) {
                const rect = this.getBoundingClientRect();
                const ripple = document.createElement('span');
                ripple.classList.add('ripple');
                const size = Math.max(rect.width, rect.height);
                ripple.style.width = ripple.style.height = size + 'px';
                ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
                ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
                this.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });

        // ============================================
        // REASON CARDS SCROLL REVEAL
        // ============================================
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const delay = parseInt(entry.target.getAttribute('data-delay')) || 0;
                    setTimeout(() => entry.target.classList.add('visible'), delay);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        document.querySelectorAll('.reason-card').forEach(card => observer.observe(card));

        // ============================================
        // REDIRECT COUNTDOWN (optional auto-redirect)
        // ============================================
        const btnGoHome = document.getElementById('btnGoHome');
        const redirectBar = document.getElementById('redirectBar');
        const barFill = document.getElementById('barFill');

        btnGoHome.addEventListener('mouseenter', function () {
            redirectBar.classList.add('active');
            let progress = 0;
            const interval = setInterval(() => {
                progress += 2;
                barFill.style.width = progress + '%';
                if (progress >= 100) clearInterval(interval);
            }, 30);
            this._interval = interval;
        });

        btnGoHome.addEventListener('mouseleave', function () {
            clearInterval(this._interval);
            barFill.style.width = '0%';
            setTimeout(() => redirectBar.classList.remove('active'), 300);
        });

        // ============================================
        // MOUSE PARALLAX ON HERO
        // ============================================
        const hero = document.getElementById('deniedHero');
        hero.addEventListener('mousemove', function (e) {
            const rect = this.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width - 0.5;
            const y = (e.clientY - rect.top) / rect.height - 0.5;
            const lockIcon = document.getElementById('lockIcon');
            lockIcon.style.transform = `translate(${x * 15}px, ${y * 15}px)`;
        });

        hero.addEventListener('mouseleave', function () {
            const lockIcon = document.getElementById('lockIcon');
            lockIcon.style.transform = 'translate(0,0)';
        });
    </script>
}