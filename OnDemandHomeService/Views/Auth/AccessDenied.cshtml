@* @{

    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Denied — Security Violation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --bg-card: rgba(15, 15, 25, 0.85);
            --fg: #e8e8f0;
            --muted: #5a5a72;
            --accent: #ff2e2e;
            --accent-glow: rgba(255, 46, 46, 0.4);
            --amber: #ff8c00;
            --amber-glow: rgba(255, 140, 0, 0.3);
            --border: rgba(255, 46, 46, 0.15);
            --card-border: rgba(255, 46, 46, 0.25);
            --green: #00ff6a;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--fg);
            font-family: 'Rajdhani', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* === BACKGROUND GRID === */
        .bg-grid {
            position: fixed;
            inset: 0;
            background-image: linear-gradient(rgba(255, 46, 46, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 46, 46, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            z-index: 0;
            animation: gridShift 20s linear infinite;
        }

        @@keyframes gridShift {
            0%

        {
            transform: translate(0, 0);
        }

        100% {
            transform: translate(60px, 60px);
        }

        }

        /* === SCAN LINE === */
        .scanline {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            z-index: 1000;
            opacity: 0.6;
            animation: scanDown 3s ease-in-out infinite;
            box-shadow: 0 0 30px var(--accent-glow), 0 0 80px var(--accent-glow);
        }

        @@keyframes scanDown {
            0%

        {
            top: -10px;
            opacity: 0;
        }

        10% {
            opacity: 0.6;
        }

        90% {
            opacity: 0.6;
        }

        100% {
            top: 100vh;
            opacity: 0;
        }

        }

        /* === FLOATING PARTICLES (Canvas behind) === */
        #particles-canvas {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
        }

        /* === CORNER BRACKETS === */
        .corner-bracket {
            position: fixed;
            width: 80px;
            height: 80px;
            z-index: 50;
            opacity: 0.5;
        }

            .corner-bracket::before, .corner-bracket::after {
                content: '';
                position: absolute;
                background: var(--accent);
            }

            .corner-bracket.tl {
                top: 20px;
                left: 20px;
            }

                .corner-bracket.tl::before {
                    top: 0;
                    left: 0;
                    width: 30px;
                    height: 2px;
                }

                .corner-bracket.tl::after {
                    top: 0;
                    left: 0;
                    width: 2px;
                    height: 30px;
                }

            .corner-bracket.tr {
                top: 20px;
                right: 20px;
            }

                .corner-bracket.tr::before {
                    top: 0;
                    right: 0;
                    width: 30px;
                    height: 2px;
                }

                .corner-bracket.tr::after {
                    top: 0;
                    right: 0;
                    width: 2px;
                    height: 30px;
                }

            .corner-bracket.bl {
                bottom: 20px;
                left: 20px;
            }

                .corner-bracket.bl::before {
                    bottom: 0;
                    left: 0;
                    width: 30px;
                    height: 2px;
                }

                .corner-bracket.bl::after {
                    bottom: 0;
                    left: 0;
                    width: 2px;
                    height: 30px;
                }

            .corner-bracket.br {
                bottom: 20px;
                right: 20px;
            }

                .corner-bracket.br::before {
                    bottom: 0;
                    right: 0;
                    width: 30px;
                    height: 2px;
                }

                .corner-bracket.br::after {
                    bottom: 0;
                    right: 0;
                    width: 2px;
                    height: 30px;
                }

        /* === MAIN CONTENT === */
        .main-wrapper {
            position: relative;
            z-index: 10;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .denied-container {
            max-width: 800px;
            width: 100%;
        }

        /* === TOP STATUS BAR === */
        .status-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeSlideDown 0.6s 0.3s forwards;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.8rem;
            color: var(--muted);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            animation: pulseDot 1.5s ease-in-out infinite;
            box-shadow: 0 0 8px var(--accent-glow);
        }

        @@keyframes pulseDot {
            0%, 100%

        {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.4;
            transform: scale(0.7);
        }

        }

        /* === MAIN CARD === */
        .denied-card {
            background: var(--bg-card);
            border: 1px solid var(--card-border);
            border-radius: 4px;
            padding: 3rem 2.5rem;
            position: relative;
            overflow: hidden;
            opacity: 0;
            animation: cardAppear 0.8s 0.5s forwards;
            backdrop-filter: blur(20px);
        }

            .denied-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--accent), var(--amber), var(--accent), transparent);
                animation: borderSlide 3s 1s linear infinite;
            }

            .denied-card::after {
                content: '';
                position: absolute;
                bottom: 0;
                right: -100%;
                width: 100%;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--accent), var(--amber), var(--accent), transparent);
                animation: borderSlideReverse 3s 1.5s linear infinite;
            }

        @@keyframes borderSlide {
            0%

        {
            left: -100%;
        }

        100% {
            left: 100%;
        }

        }
        @@keyframes borderSlideReverse {
            0%

        {
            right: -100%;
        }

        100% {
            right: 100%;
        }

        }

        @@keyframes cardAppear {
            0%

        {
            opacity: 0;
            transform: translateY(30px) scale(0.97);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        }

        @@keyframes fadeSlideDown {
            0%

        {
            opacity: 0;
            transform: translateY(-15px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* === SHIELD ICON === */
        .shield-container {
            text-align: center;
            margin-bottom: 2rem;
            opacity: 0;
            animation: shieldAppear 1s 0.8s forwards;
        }

        .shield-icon {
            font-size: 5rem;
            color: var(--accent);
            position: relative;
            display: inline-block;
            animation: shieldPulse 2s ease-in-out infinite;
            filter: drop-shadow(0 0 20px var(--accent-glow)) drop-shadow(0 0 60px rgba(255, 46, 46, 0.15));
        }

            .shield-icon .ring {
                position: absolute;
                inset: -25px;
                border: 2px solid var(--accent);
                border-radius: 50%;
                opacity: 0;
                animation: ringExpand 2s ease-out infinite;
            }

                .shield-icon .ring:nth-child(2) {
                    animation-delay: 0.6s;
                }

                .shield-icon .ring:nth-child(3) {
                    animation-delay: 1.2s;
                }

        @@keyframes ringExpand {
            0%

        {
            transform: scale(0.8);
            opacity: 0.6;
        }

        100% {
            transform: scale(2);
            opacity: 0;
        }

        }

        @@keyframes shieldPulse {
            0%, 100%

        {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        }

        @@keyframes shieldAppear {
            0%

        {
            opacity: 0;
            transform: scale(0.5);
        }

        60% {
            transform: scale(1.1);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }

        }

        /* === GLITCH TITLE === */
        .denied-title {
            text-align: center;
            font-family: 'Share Tech Mono', monospace;
            font-size: clamp(2.5rem, 7vw, 4.5rem);
            font-weight: 700;
            color: var(--fg);
            position: relative;
            margin-bottom: 0.5rem;
            opacity: 0;
            animation: titleAppear 0.5s 1.2s forwards;
        }

            .denied-title .glitch {
                position: relative;
                display: inline-block;
            }

                .denied-title .glitch::before,
                .denied-title .glitch::after {
                    content: attr(data-text);
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                }

                .denied-title .glitch::before {
                    color: var(--accent);
                    animation: glitch1 3s infinite;
                    clip-path: inset(0 0 60% 0);
                }

                .denied-title .glitch::after {
                    color: var(--amber);
                    animation: glitch2 3s infinite;
                    clip-path: inset(40% 0 0 0);
                }

        @@keyframes glitch1 {
            0%, 90%, 100%

        {
            transform: translate(0);
        }

        92% {
            transform: translate(-4px, -2px);
        }

        94% {
            transform: translate(4px, 2px);
        }

        96% {
            transform: translate(-2px, 1px);
        }

        98% {
            transform: translate(2px, -1px);
        }

        }

        @@keyframes glitch2 {
            0%, 88%, 100%

        {
            transform: translate(0);
        }

        90% {
            transform: translate(3px, 1px);
        }

        93% {
            transform: translate(-3px, -1px);
        }

        96% {
            transform: translate(2px, 2px);
        }

        }

        @@keyframes titleAppear {
            0%

        {
            opacity: 0;
            transform: translateY(20px);
            letter-spacing: 20px;
        }

        100% {
            opacity: 1;
            transform: translateY(0);
            letter-spacing: 4px;
        }

        }

        /* === ERROR CODE === */
        .error-code {
            text-align: center;
            font-family: 'Share Tech Mono', monospace;
            font-size: 1rem;
            color: var(--accent);
            letter-spacing: 6px;
            margin-bottom: 2rem;
            opacity: 0;
            animation: fadeSlideDown 0.5s 1.5s forwards;
        }

        /* === WARNING MESSAGES === */
        .warning-list {
            list-style: none;
            padding: 0;
            margin: 0 0 2rem 0;
        }

            .warning-list li {
                display: flex;
                align-items: flex-start;
                gap: 0.75rem;
                padding: 0.65rem 1rem;
                margin-bottom: 0.5rem;
                border-left: 3px solid transparent;
                font-size: 0.95rem;
                color: var(--muted);
                border-radius: 0 4px 4px 0;
                opacity: 0;
                transform: translateX(-20px);
                transition: all 0.3s ease;
            }

                .warning-list li.visible {
                    opacity: 1;
                    transform: translateX(0);
                }

                .warning-list li:hover {
                    background: rgba(255, 46, 46, 0.05);
                    border-left-color: var(--accent);
                    color: var(--fg);
                }

                .warning-list li i {
                    color: var(--amber);
                    font-size: 0.85rem;
                    margin-top: 4px;
                    flex-shrink: 0;
                }

                .warning-list li.danger i {
                    color: var(--accent);
                }

                .warning-list li.danger:hover {
                    border-left-color: var(--accent);
                    background: rgba(255, 46, 46, 0.08);
                }

        /* === TERMINAL BOX === */
        .terminal-box {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 46, 46, 0.12);
            border-radius: 4px;
            padding: 1.2rem 1.5rem;
            margin-bottom: 2rem;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.78rem;
            line-height: 1.8;
            color: var(--muted);
            opacity: 0;
            animation: cardAppear 0.6s 2.2s forwards;
            position: relative;
            overflow: hidden;
        }

            .terminal-box .terminal-header {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                margin-bottom: 0.8rem;
                padding-bottom: 0.6rem;
                border-bottom: 1px solid rgba(255, 46, 46, 0.08);
            }

                .terminal-box .terminal-header span {
                    width: 10px;
                    height: 10px;
                    border-radius: 50%;
                }

                    .terminal-box .terminal-header span:nth-child(1) {
                        background: var(--accent);
                    }

                    .terminal-box .terminal-header span:nth-child(2) {
                        background: var(--amber);
                    }

                    .terminal-box .terminal-header span:nth-child(3) {
                        background: var(--green);
                    }

                .terminal-box .terminal-header .title {
                    margin-left: 0.5rem;
                    font-size: 0.7rem;
                    color: var(--muted);
                    letter-spacing: 1px;
                }

        .terminal-line {
            opacity: 0;
        }

            .terminal-line.typed {
                opacity: 1;
            }

            .terminal-line .prompt {
                color: var(--accent);
            }

            .terminal-line .cmd {
                color: var(--fg);
            }

            .terminal-line .output {
                color: var(--muted);
            }

            .terminal-line .error-text {
                color: var(--accent);
            }

            .terminal-line .warn-text {
                color: var(--amber);
            }

            .terminal-line .success-text {
                color: var(--green);
            }

        .cursor-blink {
            display: inline-block;
            width: 8px;
            height: 14px;
            background: var(--accent);
            animation: blink 0.8s step-end infinite;
            vertical-align: middle;
            margin-left: 2px;
        }

        @@keyframes blink {
            0%, 100%

        {
            opacity: 1;
        }

        50% {
            opacity: 0;
        }

        }

        /* === SECURITY SCAN BAR === */
        .scan-section {
            margin-bottom: 2rem;
            opacity: 0;
            animation: cardAppear 0.6s 2.6s forwards;
        }

        .scan-label {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.75rem;
            color: var(--muted);
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        .scan-bar-outer {
            width: 100%;
            height: 4px;
            background: rgba(255, 46, 46, 0.1);
            border-radius: 2px;
            overflow: hidden;
            position: relative;
        }

        .scan-bar-inner {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--accent), var(--amber));
            border-radius: 2px;
            position: relative;
            transition: width 0.1s linear;
            box-shadow: 0 0 12px var(--accent-glow);
        }

            .scan-bar-inner::after {
                content: '';
                position: absolute;
                right: 0;
                top: -3px;
                width: 2px;
                height: 10px;
                background: white;
                box-shadow: 0 0 8px white;
            }

        /* === ACTION BUTTONS === */
        .actions-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            opacity: 0;
            animation: fadeSlideDown 0.6s 3s forwards;
        }

        .btn-denied {
            flex: 1;
            min-width: 180px;
            padding: 0.85rem 1.5rem;
            border: 1px solid var(--card-border);
            border-radius: 4px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            position: relative;
            overflow: hidden;
            background: transparent;
            color: var(--fg);
        }

            .btn-denied::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, var(--accent), var(--amber));
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            .btn-denied:hover::before {
                opacity: 0.15;
            }

            .btn-denied:hover {
                border-color: var(--accent);
                box-shadow: 0 0 20px rgba(255, 46, 46, 0.15), inset 0 0 20px rgba(255, 46, 46, 0.05);
                transform: translateY(-2px);
            }

            .btn-denied:active {
                transform: translateY(0);
            }

            .btn-denied.primary {
                background: linear-gradient(135deg, var(--accent), #cc1a1a);
                border-color: var(--accent);
                color: white;
                box-shadow: 0 4px 20px var(--accent-glow);
            }

                .btn-denied.primary::before {
                    background: linear-gradient(135deg, #ff5555, var(--amber));
                }

                .btn-denied.primary:hover {
                    box-shadow: 0 6px 30px var(--accent-glow), 0 0 60px rgba(255, 46, 46, 0.1);
                }

            .btn-denied span, .btn-denied i {
                position: relative;
                z-index: 2;
            }

        /* === FOOTER INFO === */
        .footer-info {
            text-align: center;
            margin-top: 2rem;
            opacity: 0;
            animation: fadeSlideDown 0.6s 3.4s forwards;
        }

            .footer-info .meta {
                font-family: 'Share Tech Mono', monospace;
                font-size: 0.7rem;
                color: var(--muted);
                letter-spacing: 2px;
                line-height: 2;
            }

                .footer-info .meta .highlight {
                    color: var(--accent);
                }

        /* === TOAST NOTIFICATION === */
        .toast-container {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .toast-msg {
            background: var(--bg-card);
            border: 1px solid var(--card-border);
            border-left: 3px solid var(--accent);
            border-radius: 4px;
            padding: 0.85rem 1.2rem;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.78rem;
            color: var(--fg);
            backdrop-filter: blur(20px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            transform: translateX(120%);
            animation: toastIn 0.4s forwards;
            max-width: 360px;
        }

            .toast-msg.leaving {
                animation: toastOut 0.3s forwards;
            }

            .toast-msg i {
                color: var(--accent);
                font-size: 1rem;
                flex-shrink: 0;
            }

        @@keyframes toastIn {
            0%

        {
            transform: translateX(120%);
            opacity: 0;
        }

        100% {
            transform: translateX(0);
            opacity: 1;
        }

        }

        @@keyframes toastOut {
            0%

        {
            transform: translateX(0);
            opacity: 1;
        }

        100% {
            transform: translateX(120%);
            opacity: 0;
        }

        }

        /* === COUNTDOWN === */
        .countdown-section {
            text-align: center;
            margin-top: 1.5rem;
            opacity: 0;
            animation: fadeSlideDown 0.5s 3.6s forwards;
        }

        .countdown-text {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.8rem;
            color: var(--muted);
            letter-spacing: 1px;
        }

        .countdown-number {
            font-size: 1.4rem;
            color: var(--accent);
            font-weight: 700;
            display: inline-block;
            min-width: 1.5ch;
            text-align: center;
        }

        /* === NOISE OVERLAY === */
        .noise-overlay {
            position: fixed;
            inset: 0;
            z-index: 999;
            pointer-events: none;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            background-repeat: repeat;
            background-size: 256px 256px;
        }

        /* === VIGNETTE === */
        .vignette {
            position: fixed;
            inset: 0;
            z-index: 998;
            pointer-events: none;
            background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.6) 100%);
        }

        /* === RESPONSIVE === */
        @@media (max-width: 640px) {
            .denied-card

        {
            padding: 2rem 1.5rem;
        }

        .shield-icon {
            font-size: 3.5rem;
        }

        .actions-row {
            flex-direction: column;
        }

        .btn-denied {
            min-width: 100%;
        }

        .corner-bracket {
            width: 50px;
            height: 50px;
        }

            .corner-bracket::before {
                width: 20px !important;
            }

            .corner-bracket::after {
                height: 20px !important;
            }

        }

        /* === REDUCED MOTION === */
        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after

        {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }

        .scanline {
            display: none;
        }

        }
    </style>
</head>
<body>

    <!-- Background layers -->
    <div class="bg-grid"></div>
    <canvas id="particles-canvas"></canvas>
    <div class="noise-overlay"></div>
    <div class="vignette"></div>
    <div class="scanline"></div>

    <!-- Corner brackets -->
    <div class="corner-bracket tl"></div>
    <div class="corner-bracket tr"></div>
    <div class="corner-bracket bl"></div>
    <div class="corner-bracket br"></div>

    <!-- Toast container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Main content -->
    <main class="main-wrapper">
        <div class="denied-container">

            <!-- Status bar -->
            <div class="status-bar">
                <div class="status-dot"></div>
                <span>Security Monitoring Active</span>
                <span style="margin-left: auto;" id="liveTime"></span>
            </div>

            <!-- Main card -->
            <div class="denied-card">

                <!-- Shield icon -->
                <div class="shield-container">
                    <div class="shield-icon">
                        <i class="fa-solid fa-shield-halved"></i>
