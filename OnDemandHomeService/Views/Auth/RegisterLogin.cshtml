                <input type="password" name="Password" placeholder="Password" required />
                <a href="#" class="mt-2" style="text-decoration:none; font-size:0.85rem; color:#667eea;">Forgot your password?</a>
                <button type="submit" class="btn-submit">Sign In</button>
                <div id="loginMsg" class="form-msg"></div>
            </form>
        </div>

        <!-- Overlay (desktop only) -->
        <div class="overlay-container">
            <div class="overlay">
                <div class="overlay-panel overlay-left">
                    <h1>Welcome Back!</h1>
                    <p>To keep connected with us please login with your personal info</p>
                    <button class="ghost btn-submit" id="signIn">Sign In</button>
                </div>
                <div class="overlay-panel overlay-right">
                    <h1>Hello, Friend!</h1>
                    <p>Enter your personal details and start your journey with us</p>
                    <button class="ghost btn-submit" id="signUp">Sign Up</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            const $container = $('#container');
            const $mobileToggles = $('.mobile-toggle-bar .toggle-btn');
            const isMobile = () => $(window).width() <= 768;

            // ===== Switch to Sign Up =====
            function showSignUp() {
                if (isMobile()) {
                    $container.addClass('mobile-signup');
                    $container.removeClass('right-panel-active');
                } else {
                    $container.addClass('right-panel-active');
                    $container.removeClass('mobile-signup');
                }
                $mobileToggles.removeClass('active');
                $mobileToggles.filter('[data-target="signup"]').addClass('active');
            }

            // ===== Switch to Sign In =====
            function showSignIn() {
                if (isMobile()) {
                    $container.removeClass('mobile-signup');
                    $container.removeClass('right-panel-active');
                } else {
                    $container.removeClass('right-panel-active');
                    $container.removeClass('mobile-signup');
                }
                $mobileToggles.removeClass('active');
                $mobileToggles.filter('[data-target="signin"]').addClass('active');
            }

            // Desktop overlay buttons
            $('#signUp').on('click', showSignUp);
            $('#signIn').on('click', showSignIn);

            // Mobile toggle bar buttons
            $mobileToggles.on('click', function () {
                const target = $(this).data('target');
                if (target === 'signup') showSignUp();
                else showSignIn();
            });

            // Handle resize: clean up classes when switching between mobile/desktop
            $(window).on('resize', function () {
                $container.removeClass('right-panel-active mobile-signup');
                $mobileToggles.removeClass('active');
                $mobileToggles.filter('[data-target="signin"]').addClass('active');
            });

            // ===== AJAX Login =====
            $("#loginForm").on('submit', function (e) {
                e.preventDefault();
                const $btn = $(this).find("button[type='submit']");
                const originalText = $btn.text();

                $btn.prop('disabled', true).text("Signing In...");
                $("#loginMsg").html('');

                $.ajax({
                    url: '@Url.Action("Login", "Auth")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            $("#loginMsg").html('<span style="color:green;">Login Successful! Redirecting...</span>');
                            setTimeout(() => { window.location.href = res.redirect; }, 500);
                        } else {
                            $("#loginMsg").html('<span style="color:red;">' + res.message + '</span>');
                            $btn.prop('disabled', false).text(originalText);
                        }
                    },
                    error: function () {
                        $("#loginMsg").html('<span style="color:red;">An error occurred. Please try again.</span>');
                        $btn.prop('disabled', false).text(originalText);
                    }
                });
            });

            // ===== AJAX Register =====
            $("#registerForm").on('submit', function (e) {
                e.preventDefault();
                const $btn = $(this).find("button[type='submit']");
                const originalText = $btn.text();

                $btn.prop('disabled', true).text("Creating Account...");
                $("#regMsg").html('');

                $.ajax({
                    url: '@Url.Action("Register", "Auth")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            $("#regMsg").html('<span style="color:green;">Registration Successful! Redirecting to login...</span>');
                            $("#registerForm")[0].reset();
                            setTimeout(() => { showSignIn(); }, 1000);
                        } else {
                            $("#regMsg").html('<span style="color:red;">' + res.message + '</span>');
                        }
                        $btn.prop('disabled', false).text(originalText);
                    },
                    error: function () {
                        $("#regMsg").html('<span style="color:red;">An error occurred. Please try again.</span>');
                        $btn.prop('disabled', false).text(originalText);
                    }
                });
            });
        });
    </script>
</body>
</html>