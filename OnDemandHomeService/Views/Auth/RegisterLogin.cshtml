            animation: showPanel 0.6s ease-in-out;
        }

        @@keyframes showPanel {
            0%, 49.99%

        {
            opacity: 0;
            z-index: 1;
        }

        50%, 100% {
            opacity: 1;
            z-index: 5;
        }

        }

        /* ===== OVERLAY ===== */
        .overlay-container {
            position: absolute;
            top: 0;
            left: 50%;
            width: 50%;
            height: 100%;
            overflow: hidden;
            transition: transform 0.6s ease-in-out;
            z-index: 100;
        }

        .main-container.right-panel-active .overlay-container {
            transform: translateX(-100%);
        }

        .overlay {
