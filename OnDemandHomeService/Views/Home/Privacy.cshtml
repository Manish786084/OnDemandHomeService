@section Scripts {
    <script>
        // ==============================
        // Tab Switching
        // ==============================
        function switchTab(el) {
            // Remove active from all tabs
            document.querySelectorAll('.policy-tab').forEach(tab => tab.classList.remove('active'));
            el.classList.add('active');

            const target = el.getAttribute('data-target');

            // Hide all content
            document.getElementById('termsContent').style.display = 'none';
            document.getElementById('privacyContent').style.display = 'none';
            document.getElementById('tocTerms').style.display = 'none';
            document.getElementById('tocPrivacy').style.display = 'none';

            // Show selected
            document.querySelector(target).style.display = 'block';

            // Show matching TOC
            if (target === '#termsContent') {
                document.getElementById('tocTerms').style.display = 'block';
            } else {
                document.getElementById('tocPrivacy').style.display = 'block';
            }

            // Scroll to top of content
            window.scrollTo({ top: 300, behavior: 'smooth' });
        }

        // ==============================
        // Smooth Scroll to Section
        // ==============================
        function scrollToSection(event, sectionId) {
            event.preventDefault();
            const section = document.getElementById(sectionId);
            if (section) {
                const yOffset = -80;
                const y = section.getBoundingClientRect().top + window.pageYOffset + yOffset;
                window.scrollTo({ top: y, behavior: 'smooth' });

                // Highlight active TOC link
                document.querySelectorAll('.toc-link').forEach(link => link.classList.remove('active'));
                event.target.classList.add('active');
            }
        }

        // ==============================
        // Scroll to Top
        // ==============================
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.addEventListener('scroll', function () {
            const btn = document.getElementById('scrollTopBtn');
            if (window.scrollY > 400) {
                btn.style.display = 'flex';
                btn.style.alignItems = 'center';
                btn.style.justifyContent = 'center';
            } else {
                btn.style.display = 'none';
            }
        });

        // ==============================
        // Active TOC on Scroll
        // ==============================
        window.addEventListener('scroll', function () {
            const sections = document.querySelectorAll('.terms-section');
            const tocLinks = document.querySelectorAll('.toc-link');

            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop - 120;
                if (window.pageYOffset >= sectionTop) {
                    current = section.getAttribute('id');
                }
            });

            tocLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                }
            });
        });

        // ==============================
        // Accept Terms (Demo)
        // ==============================
        function acceptTerms() {
            const btn = event.target.closest('.btn-accept');
            btn.innerHTML = '<i class="fas fa-check me-2"></i>Accepted!';
            btn.style.background = '#22c55e';
            btn.style.color = '#fff';

            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-thumbs-up me-2"></i>I Accept the Terms';
                btn.style.background = '#fff';
                btn.style.color = '#4e73df';
            }, 2500);
        }
    </script>
}
