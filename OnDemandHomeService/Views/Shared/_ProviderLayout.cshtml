<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Provider Panel | HomeService</title>

    <!-- 1. Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- 2. Font Awesome for Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- 3. Custom CSS for Layout -->
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* --- SIDEBAR STYLES (Fixed Left) --- */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 260px;
            background-color: #1a252f; /* Darker shade for Provider distinction */
            color: #fff;
            z-index: 1030;
            transition: all 0.3s ease;
            overflow-y: auto;
        }

            .sidebar .logo-header {
                padding: 20px;
                border-bottom: 1px solid #2d3a47;
                text-align: center;
            }

            .sidebar .nav-item a {
                color: #adb5bd;
                padding: 14px 20px;
                display: flex;
                align-items: center;
                text-decoration: none;
                transition: 0.2s;
            }

                .sidebar .nav-item a i {
                    margin-right: 12px;
                    width: 20px;
                    text-align: center;
                }

                .sidebar .nav-item a:hover,
                .sidebar .nav-item.active a {
                    background-color: #2d3a47;
                    color: #fff;
                    border-left: 4px solid #1cc88a; /* Green accent for active state */
                }

        /* --- MAIN PANEL STYLES --- */
        .main-panel {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- TOP HEADER STYLES --- */
        .main-header {
            position: fixed;
            top: 0;
            right: 0;
            width: calc(100% - 260px);
            height: 65px;
            background-color: #fff;
            border-bottom: 1px solid #e3e6f0;
            z-index: 1020;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
        }

        /* --- CONTENT WRAPPER (Scrollable) --- */
        .content-wrapper {
            margin-top: 65px;
            padding: 25px;
            flex-grow: 1;
            background-color: #f8f9fa;
            min-height: calc(100vh - 65px);
        }

        /* Provider Status Dot */
        .status-dot {
            width: 8px;
            height: 8px;
            background-color: #1cc88a;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%

        {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }

        }

        /* Card styling */
        .card {
            border: none;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>

    <!-- ========================================= -->
    <!-- 1. LEFT SIDEBAR (Fixed Position) -->
    <!-- ========================================= -->
    <div class="sidebar">
        <div class="logo-header">
            <h4 class="text-white mb-0"><i class="fas fa-tools me-2 text-success"></i>ServicePro</h4>
            <small class="text-muted">Provider Dashboard</small>
        </div>

        <div class="sidebar-wrapper mt-3">
            <ul class="nav flex-column">
                <li class="nav-item active">
                    <a href="@Url.Action("Dashboard", "Provider")">
                        <i class="fas fa-home"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("NewRequest", "Provider")">
                        <i class="fas fa-bell"></i> New Requests
                        <span class="badge bg-danger ms-auto">3</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Bookings", "ProviderService")">
                        <i class="fas fa-clipboard-list"></i> All Bookings
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("MyServices", "ProviderService")">
                        <i class="fas fa-calendar-alt"></i> Add Services
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Earnings", "Provider")">
                        <i class="fas fa-wallet"></i> Earnings
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Reviews", "ProviderDashboard")">
                        <i class="fas fa-star"></i> My Reviews
                    </a>
                </li>

                <li class="nav-section mt-3 px-3">
                    <span class="text-uppercase text-muted small">Account</span>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("Profile", "ProviderDashboard")">
                        <i class="fas fa-user"></i> My Profile
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Settings", "ProviderDashboard")">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <a href="@Url.Action("Logout", "Auth")" class="text-danger">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- ========================================= -->
    <!-- 2. MAIN PANEL -->
    <!-- ========================================= -->
    <div class="main-panel">

        <!-- A. TOP HEADER -->
        <nav class="main-header">
            <!-- Left Side: Search or Title -->
            <div class="d-flex align-items-center">
                <h5 class="mb-0 fw-bold text-dark">@ViewData["Title"]</h5>
            </div>

            <!-- Right Side: Profile & Notifications -->
            <div class="d-flex align-items-center">
                <!-- Online Status Toggle -->
                <div class="me-4 d-none d-md-block">
                    <span class="status-dot"></span>
                    <span class="text-success small fw-bold">You are Online</span>
                </div>

                <!-- Notifications -->
                <div class="dropdown me-2">
                    <a href="#" class="position-relative" data-bs-toggle="dropdown">
                        <i class="fas fa-bell fa-lg text-dark"></i>

                        @if (ViewBag.NotificationCount != null && (int)ViewBag.NotificationCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                  style="font-size: 9px;">
                                @ViewBag.NotificationCount
                            </span>
                        }
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        @await Component.InvokeAsync("Notification")
                    </ul>
                </div>

                <!-- Profile Dropdown -->
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                        <img src="https://ui-avatars.com/api/?name=Provider+One&background=1cc88a&color=fff"
                             class="rounded-circle me-2" height="35" alt="Profile">
                        <span class="d-none d-lg-inline text-dark fw-bold">Provider One</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><strong class="ms-2">@Context.Session.GetString("FullName")</strong></li>
                        <li> <p class="mb-0 ms-2 text-muted small">@Context.Session.GetString("Email")</p></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2 text-muted"></i> Profile</a></li>
                        <li><a class="dropdown-item" href="#"><i class="fas fa-cog me-2 text-muted"></i> Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" asp-action="Logout" asp-controller="Auth"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- B. CONTENT WRAPPER (Scrollable) -->
        <div class="content-wrapper">
            <!-- Render Specific Page Content Here -->
            @RenderBody()

            <!-- FOOTER -->
            <footer class="footer mt-5 py-3 text-center">
                <div class="container">
                    <span class="text-muted">Copyright &copy; @DateTime.Now.Year FixItNow HomeService Provider Panel. All rights reserved.</span>
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>