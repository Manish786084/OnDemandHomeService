@model OnDemandHomeService.ViewModels.NotificationVM

<li class="dropdown-header d-flex justify-content-between">
    <span>Notifications</span>

    @if (Model.Count > 0)
    {
        <span class="badge bg-danger">@Model.Count</span>
    }
</li>

@if (Model.Notifications.Any())
{
    foreach (var n in Model.Notifications)
    {
        <li>
            <a class="dropdown-item"
               href="@Url.Action("MarkAsRead", "Notification", new { id = n.NotificationId })">

                <strong>@n.Title</strong><br />
                <small class="text-muted">@n.Message</small>
            </a>
        </li>
    }
}
else
{
    <li>
        <span class="dropdown-item text-muted">No notifications</span>
    </li>
}