@model OnDemandHomeService.ViewModels.ProviderDashboardVM
@using System.Linq
@{
    Layout = "~/Views/Shared/_ProviderLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<!-- SECTION 1: OVERVIEW STATS -->
<div class="row">
    <!-- Earnings Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Today's Earnings
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">₹ @Model.TodayEarnings</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Completed Jobs Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Completed Jobs
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.CompletedJobs</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Rating Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Avg. Rating
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">4.9 <i class="fas fa-star text-warning fa-sm"></i></div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-star fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Requests Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                            New Requests
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.NewRequests</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-bell fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SECTION 2: NEW BOOKING REQUESTS (Actionable) -->
<div class="row">
    <div class="col-lg-12 mb-4">
        <div class="card shadow border-top-danger">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-danger"><i class="fas fa-exclamation-circle me-2"></i>New Booking Requests</h6>
                <span class="badge bg-danger">Requires Action</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Service</th>
                                <th>Customer</th>
                                <th>Address / Distance</th>
                                <th>Scheduled Time</th>
                                <th>Est. Payout</th>
                                <th style="width: 15%">Action</th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model.PendingBookings)
                            {
                                <tr>

                                    <td>
                                        <span class="badge bg-info">
                                            @item.ServiceName
                                        </span>
                                    </td>

                                    <td>@item.CustomerName</td>

                                    <td>@item.Address</td>

                                    <td>@item.Time</td>

                                    <td>
                                        <strong>₹ @item.Amount</strong>
                                    </td>

                                    <td>

                                        <form asp-action="ManageBookingRequest" asp-controller="ProviderService"
                                              method="post"
                                              style="display:inline">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@item.BookingId" />

                                            <button class="btn btn-success btn-sm">
                                                View
                                            </button>

                                        </form>

                                    </td>

                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SECTION 3: SCHEDULE & EARNINGS -->
<div class="row">
    <!-- Today's Schedule -->
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Today's Confirmed Schedule</h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <!-- Job Item 1 -->
                 
                    @foreach (var item in Model.TodaySchedules)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">

                            <div class="d-flex align-items-center">

                                <div class="bg-success text-white p-2 rounded me-3 text-center"
                                     style="width: 80px;">

                                    <small>@item.Time</small>

                                </div>

                                <div>
                                    <h6 class="mb-1">@item.ServiceName</h6>

                                    <small class="text-muted">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        @item.Address
                                    </small>
                                </div>

                            </div>

                            <div class="text-end">
                                @if (@item.Status=="Paid")
                                {
                                    <span class="badge bg-secondary">
                                    @item.Status
                                    </span>
                                }
                                else if (@item.Status == "Completed")
                                {
                                    <span class="badge bg-success">
                                        @item.Status
                                    </span>
                                }
                                else if (@item.Status == "Pending")
                                {
                                    <span class="badge bg-warning">
                                        @item.Status
                                    </span>
                                }
                                else 
                                {
                                    <span class="badge bg-danger">
                                        @item.Status
                                    </span>
                                }
                                <br>

                                <small class="text-dark fw-bold">
                                    ₹ @item.Amount
                                </small>

                            </div>

                        </div>
                    }

                    <!-- Job Item 2 -->
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <div class="d-flex align-items-center">
                            <div class="bg-secondary text-white p-2 rounded me-3 text-center" style="width: 60px;">
                                <div class="font-weight-bold">02:30</div>
                                <small>PM</small>
                            </div>
                            <div>
                                <h6 class="mb-1">Bathroom Leak Check</h6>
                                <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i> 1010 Downtown Blvd</small>
                            </div>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-info">Upcoming</span>
                            <br>
                            <small class="text-dark fw-bold">$65.00</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Earnings Chart -->
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Earnings Overview</h6>
            </div>
            <div class="card-body">
                <canvas id="earningsChart" style="height: 200px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Right Side: Profile Stats & Reviews -->
    <div class="col-xl-4 col-lg-5">
        <!-- Profile Completion -->
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Profile Strength</h6>
            </div>
            <div class="card-body">
                <h4 class="small font-weight-bold">Completion <span class="float-end">85%</span></h4>
                <div class="progress mb-3">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 85%" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <p class="text-muted small mb-0">Add your ID verification to reach 100%.</p>
            </div>
        </div>

        <!-- Recent Reviews -->
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Recent Reviews</h6>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">

                            @if (Model.Reviews != null && Model.Reviews.Any())
                            {
                                foreach (var r in Model.Reviews)
                                {
                                    <li class="list-group-item">

                                        <div class="d-flex justify-content-between">
                                            <div>
                                                <strong>@r.CustomerName</strong>

                                                <!-- STAR RATING -->
                                                <div class="text-warning small">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= (r.Rating ?? 0))
                                                        {
                                                            <i class="fas fa-star"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="far fa-star"></i>
                                                        }
                                                    }
                                                </div>
                                            </div>

                                            <!-- TIME -->
                                            <small class="text-muted">
                                                @{
                                                    if (r.CreatedAt.HasValue)
                                                    {
                                                        var diff = DateTime.Now - r.CreatedAt.Value;

                                                        if (diff.TotalMinutes < 60)
                                        @($"{(int)diff.TotalMinutes} mins ago")
                                                                                else if (diff.TotalHours < 24)
                                        @($"{(int)diff.TotalHours} hrs ago")
                                                                                else
                                        @r.CreatedAt.Value.ToString("dd MMM yyyy")
                                                                                }
                                                }
                                            </small>
                                        </div>

                                        <!-- COMMENT -->
                                        <p class="mb-0 small mt-2">
                                            "@r.Comment"
                                        </p>

                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-center text-muted small">
                                    No reviews yet
                                </li>
                            }
                            
                        </ul>
                    </div>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const ctx = document.getElementById('earningsChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
                datasets: [{
                    label: "Earnings ($)",
                    lineTension: 0.3,
                    backgroundColor: "rgba(78, 115, 223, 0.05)",
                    borderColor: "rgba(78, 115, 223, 1)",
                    data: @Html.Raw(Json.Serialize(Model.WeeklyEarnings)),
                    pointBackgroundColor: "rgba(78, 115, 223, 1)",
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) { return '$' + value; }
                        }
                    }
                }
            }
        });
    </script>
}