@model List<OnDemandHomeService.Models.Payment>

@{
    Layout = "~/Views/Shared/_ProviderLayout.cshtml";
    ViewData["Title"] = "Earnings";
}

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="fas fa-wallet text-success"></i>
        Earnings Dashboard
    </h2>

    <!-- CARDS -->
    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card shadow border-start border-success border-4">
                <div class="card-body">
                    <h6>Today's Earnings</h6>

                    <h3 class="text-success">
                        ₹ @ViewBag.TodayEarning
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-start border-primary border-4">
                <div class="card-body">
                    <h6>Monthly Earnings</h6>

                    <h3 class="text-primary">
                        ₹ @ViewBag.MonthEarning
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-start border-dark border-4">
                <div class="card-body">
                    <h6>Total Earnings</h6>

                    <h3 class="text-dark">
                        ₹ @ViewBag.TotalEarning
                    </h3>
                </div>
            </div>
        </div>

    </div>

    <!-- PAYMENT HISTORY -->
    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            Payment History
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Booking</th>
                            <th>Service</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Paid Date</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    #@item.BookingId
                                </td>

                                <td>
                                    @string.Join(", ",
                                    item.Booking.BookingDetails
                                    .Select(d => d.Service.ServiceName))
                            </td>

                            <td>
                                <strong class="text-success">
                                    ₹ @item.Amount
                                </strong>
                            </td>

                            <td>
                                @item.PaymentMethod
                            </td>

                            <td>
                                <span class="badge bg-success">
                                    @item.PaymentStatus
                                </span>
                            </td>

                            <td>
                                @item.PaidAt
                            </td>

                        </tr>
                                                }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>