@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeService | Login</title>

    <!-- Dependencies -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }

        body {
            font-family: 'Poppins', sans-serif;
            height: 100vh;
            overflow: hidden;
            background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
        }

        /* Animated Background Keyframes */
        @@keyframes gradientBG {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        /* Card Glassmorphism Effect */
        .auth-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            animation: floatIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @@keyframes floatIn {
            0%

        {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        }

        /* Tab Styling */
        .nav-tabs {
            border-bottom: 2px solid rgba(0,0,0,0.1);
        }

            .nav-tabs .nav-link {
                border: none;
                color: #6c757d;
                font-weight: 600;
                padding: 12px 20px;
                transition: all 0.3s ease;
            }

                .nav-tabs .nav-link.active {
                    color: #764ba2;
                    background: transparent;
                    border-bottom: 3px solid #764ba2;
                }

                .nav-tabs .nav-link:hover {
                    border: none;
                    color: #764ba2;
                }

        /* Form Inputs */
        .input-group {
            margin-bottom: 1.2rem;
        }

        .input-group-text {
            background: transparent;
            border: 2px solid #e0e0e0;
            border-right: none;
            color: #764ba2;
        }

        .form-control {
            border: 2px solid #e0e0e0;
            border-left: none;
            padding: 12px;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #764ba2;
            }

                .form-control:focus + .input-group-text,
                .form-control:focus ~ .input-group-text {
                    border-color: #764ba2;
                }

        /* Button Styling */
        .btn-login {
            background: var(--primary-gradient);
            border: none;
            padding: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 20px rgba(102, 126, 234, 0.5);
            }

        .btn-register {
            background: var(--secondary-gradient);
            border: none;
            padding: 12px;
            font-weight: 600;
            color: white;
            letter-spacing: 0.5px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 20px rgba(245, 87, 108, 0.5);
            }

        /* Forgot Password Link */
        .forgot-link {
            color: #6c757d;
            text-decoration: none;
            transition: color 0.3s;
        }

            .forgot-link:hover {
                color: #764ba2;
                font-weight: 600;
            }

        /* Tab Fade Animation */
        .tab-pane {
            animation: fadeIn 0.3s ease;
        }
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateX(10px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }

        }

        /* Loader in button */
        .spinner-border {
            width: 1rem;
            height: 1rem;
            margin-right: 5px;
        }
    </style>
</head>
<body>

    <div class="container mt-5 d-flex align-items-center justify-content-center" style="height: 100vh;">
        <div class="col-md-5 col-lg-4 col-sm-8">

            <div class="card auth-card p-4">
                <!-- Logo Header -->
                <div class="text-center mb-3">
                    <h2 class="fw-bold text-dark">HomeService</h2>
                    <p class="text-muted small">Manage your services efficiently</p>
                </div>

                <ul class="nav nav-tabs justify-content-center mb-4" id="authTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="login-tab" data-bs-toggle="tab" data-bs-target="#loginTab" type="button" role="tab" aria-controls="loginTab" aria-selected="true">Sign In</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="register-tab" data-bs-toggle="tab" data-bs-target="#registerTab" type="button" role="tab" aria-controls="registerTab" aria-selected="false">Sign Up</button>
                    </li>
                </ul>

                <div class="tab-content">

                    <!-- LOGIN TAB -->
                    <div class="tab-pane fade show active" id="loginTab" role="tabpanel">
                        <form id="loginForm" method="post" asp-controller="Auth" asp-action="Login">

                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input class="form-control" name="Email" placeholder="Email Address" type="email" required />
                            </div>

                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                <input class="form-control" name="Password" placeholder="Password" type="password" required />
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="RememberMe" id="rememberMe" />
                                    <label class="form-check-label small" for="rememberMe">Remember me</label>
                                </div>
                                <a href="/Auth/ForgotPassword" class="small forgot-link">Forgot Password?</a>
                            </div>

                            <button type="submit" class="btn btn-primary btn-login w-100 mb-3">
                                <span class="btn-text">Login</span>
                                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                            </button>

                            <div class="text-center mt-3">
                                <small class="text-muted">Or sign in with</small><br>
                                <a href="#" class="btn btn-link text-dark"><i class="fab fa-google fa-lg"></i></a>
                                <a href="#" class="btn btn-link text-dark"><i class="fab fa-facebook fa-lg"></i></a>
                            </div>
                        </form>
                    </div>

                    <!-- REGISTER TAB -->
                    <div class="tab-pane fade" id="registerTab" role="tabpanel">
                        <form id="registerForm" method="post" asp-controller="Auth" asp-action="Register">

                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <input class="form-control" name="FullName" placeholder="Full Name" type="text" required />
                            </div>

                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input class="form-control" name="Email" placeholder="Email Address" type="email" required />
                            </div>

                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input class="form-control" name="Phone" placeholder="Phone Number" type="text" required />
                            </div>

                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                <input class="form-control" name="Password" placeholder="Password" type="password" required />
                            </div>

                            <div class="input-group mb-3">
                                <span class="input-group-text"><i class="fas fa-user-tag"></i></span>
                                <select class="form-control" name="RoleId" required>
                                    <option value="">Select Role</option>
                                    <option value="1">Customer</option>
                                    <option value="2">Provider</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-success btn-register w-100">
                                <span class="btn-text">Create Account</span>
                                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {

            // Helper function for button loading state
            function setLoading(button, isLoading) {
                var btnText = button.find('.btn-text');
                var spinner = button.find('.spinner-border');
                if (isLoading) {
                    btnText.text('Processing...');
                    spinner.removeClass('d-none');
                    button.prop('disabled', true);
                } else {
                    spinner.addClass('d-none');
                    button.prop('disabled', false);
                }
            }

            // LOGIN FORM SUBMIT
            $("#loginForm").submit(function (e) {
                e.preventDefault();
                var form = $(this);
                var btn = form.find('button[type="submit"]');

                setLoading(btn, true);

                $.ajax({
                    type: "POST",
                    url: form.attr("action"),
                    data: form.serialize(),
                    success: function (res) {
                        setLoading(btn, false);
                        if (res.success) {
                            Swal.fire({
                                title: 'Welcome Back!',
                                text: 'Login successful',
                                icon: 'success',
                                showClass: { popup: 'animate__animated animate__fadeInDown' },
                                hideClass: { popup: 'animate__animated animate__fadeOutUp' }
                            }).then(() => window.location = res.redirect);
                        } else {
                            Swal.fire({
                                title: 'Oops...',
                                text: res.message || "Invalid credentials",
                                icon: 'error',
                                showClass: { popup: 'animate__animated animate__headShake' }
                            });
                        }
                    },
                    error: function () {
                        setLoading(btn, false);
                        Swal.fire("Error", "Something went wrong", "error");
                    }
                });
            });

            // REGISTER FORM SUBMIT
            $("#registerForm").submit(function (e) {
                e.preventDefault();
                var form = $(this);
                var btn = form.find('button[type="submit"]');

                setLoading(btn, true);

                $.ajax({
                    type: "POST",
                    url: form.attr("action"),
                    data: form.serialize(),
                    success: function (res) {
                        setLoading(btn, false);
                        if (res.success) {
                            Swal.fire({
                                title: 'Account Created!',
                                text: 'Please login to continue',
                                icon: 'success',
                                showClass: { popup: 'animate__animated animate__fadeInDown' }
                            }).then(() => {
                                var loginTab = new bootstrap.Tab(document.querySelector('#login-tab'));
                                loginTab.show();
                            });
                        } else {
                            Swal.fire({
                                title: 'Error',
                                text: res.message || "Failed to register",
                                icon: 'error',
                                showClass: { popup: 'animate__animated animate__headShake' }
                            });
                        }
                    },
                    error: function () {
                        setLoading(btn, false);
                        Swal.fire("Error", "Something went wrong", "error");
                    }
                });
            });

        });
    </script>
</body>
</html>